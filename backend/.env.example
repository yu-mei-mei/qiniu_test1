# DeepSeek API Key
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# Baidu short speech recognition
BAIDU_APP_ID=你的百度AppID
BAIDU_API_KEY=你的百度APIKey
BAIDU_SECRET_KEY=你的百度SecretKey
BAIDU_DEV_PID=1537

# Optional AI image generation
OPENAI_IMAGE_API_KEY=sk-xxxxxxxxxxxx
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# Image provider selection: openai or xiaomi
IMAGE_PROVIDER=openai

# Optional Xiaomi MiMo image generation if it exposes an OpenAI-compatible images API
XIAOMI_IMAGE_API_KEY=sk-xxxxxxxxxxxx
XIAOMI_IMAGE_BASE_URL=https://example.xiaomi-api/v1
XIAOMI_IMAGE_MODEL=your-xiaomi-image-model
XIAOMI_IMAGE_SIZE=1024x1024
